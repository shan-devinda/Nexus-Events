# Copy this file to .env and fill in your values
# DO NOT commit your .env file to version control

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=1

# Security - Change this to a long random string in production!
JWT_SECRET=your-super-secret-jwt-key-change-me-in-production

# Stripe API Keys
# Get these from https://dashboard.stripe.com/apikeys
# Use test keys (sk_test_...) for development
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Frontend URL (used for Stripe redirect URLs)
FRONTEND_URL=http://localhost:5500

# Leave empty to use SQLite (default for development)
# DATABASE_URL=postgresql://user:password@localhost/eventdb
